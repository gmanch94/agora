# Copy to .env and fill in.
#
# Mirrors `Settings` in `src/agora/config.py`; runbook env-var table
# (docs/runbook.md § Configuration) is the canonical reference. Keep
# this file in sync when new vars are added.

# --- Agora app ---
AGORA_ENV=dev
AGORA_LOG_LEVEL=INFO
AGORA_API_HOST=127.0.0.1
AGORA_API_PORT=8000

# --- Database (Agora's own Postgres) ---
AGORA_DB_URL=postgresql+asyncpg://agora:agora@localhost:5433/agora
AGORA_DB_POOL_SIZE=10

# --- ReShare (FOLIO mod-rs) ---
# Point to your ReShare base URL. Empty → in-process mock client (offline
# dev + tests). Non-empty → HttpReShareClient (live HTTP).
RESHARE_BASE_URL=
RESHARE_TENANT=consortium-a
RESHARE_USER=
RESHARE_PASSWORD=
# When set, HttpReShareClient authenticates via the FOLIO Okapi token flow
# (POST {OKAPI_URL}/authn/login → x-okapi-token header) instead of HTTP
# Basic. Reuses RESHARE_USER / RESHARE_PASSWORD as Okapi credentials.
# See ADR-0013.
OKAPI_URL=
#
# Local mod-rs sandbox (profile: reshare — see docker-compose.yml).
# Use these values when running `make reshare-up` / `make reshare-probe`.
# Hit mod-rs direct on :8081 (bypasses Okapi; HTTP Basic works because
# permissions are disabled on the direct port — dev path only).
#
#   RESHARE_BASE_URL=http://localhost:8081
#   RESHARE_TENANT=consortium-a
#   RESHARE_USER=admin
#   RESHARE_PASSWORD=admin
#   OKAPI_URL=   # leave empty — probe goes direct, no Okapi in loop

# --- NCIP (mod-ncip) ---
NCIP_BASE_URL=
NCIP_AGENCY_ID=AGORA-DEV

# --- Discovery — SRU ---
# Explicit boolean toggle (false → MockSruClient; true → HttpSruClient).
# Cannot mirror RESHARE_BASE_URL's URL-presence convention because
# SRU_LOC_URL ships with a non-empty production default.
AGORA_SRU_ENABLED=false
SRU_LOC_URL=https://lx2.loc.gov/voyager
SRU_TIMEOUT_SECS=5

# --- Discovery — CrossRef ---
# Explicit boolean toggle (see AGORA_SRU_ENABLED rationale).
AGORA_CROSSREF_ENABLED=false
CROSSREF_BASE_URL=https://api.crossref.org
CROSSREF_TIMEOUT_SECS=5
# When set, opts into CrossRef's polite pool with
# `User-Agent: Agora/0.1 (mailto:<value>)` for better rate-limit treatment.
CROSSREF_MAILTO=

# --- Discovery — Consortium roster ---
# Comma-separated list of in-consortium agency symbols (e.g.
# `MEMBER1, MEMBER2`). Threaded into DiscoveryAgent.consortium_members
# at app build time. Whitespace stripped per token; duplicates collapse;
# trailing commas tolerated. Empty default → no candidate flagged
# in-consortium.
AGORA_CONSORTIUM_MEMBERS=

# --- Saga coordinator + outbox ---
SAGA_STALL_TIMEOUT_SECS=600
OUTBOX_RETRY_MAX_ATTEMPTS=10
# Set to 0/false to suppress the lifespan-spawned outbox worker (e.g.
# when running migrations standalone).
AGORA_OUTBOX_WORKER_ENABLED=true
AGORA_OUTBOX_POLL_INTERVAL_SECS=1.0

# --- TrackingAgent (overdue scanner) ---
# Set to 0/false to suppress the lifespan-spawned overdue scanner.
AGORA_TRACKING_SCANNER_ENABLED=true
AGORA_TRACKING_SCAN_INTERVAL_SECS=300.0
# Tier-2: days past due_at before `recall-proposed` advisory fires.
AGORA_TRACKING_RECALL_AFTER_DAYS=14
# Tier-3: days past shipped_at (no RECEIVE event) before
# `receipt-unconfirmed` advisory fires. Independent of tier-1/2 — tracks
# transit time rather than loan-clock time.
AGORA_TRACKING_UNCONFIRMED_RECEIPT_AFTER_DAYS=7

# --- RoutingAgent LLM tie-breaker (ADR-0014) ---
# Top-2 score gap below which the rules baseline consults the LLM.
# Tightened from 0.05 → 0.03 in #51 / #7c.
AGORA_ROUTING_TIEBREAK_EPSILON=0.03
# Opt-in for the AdkLlmTiebreaker. Requires bound GCP ADC + Vertex AI
# API enabled on the project. Default `false` keeps RoutingAgent
# byte-identical to the rules-only baseline.
AGORA_ROUTING_LLM_ENABLED=false
# gemini-2.5-flash matches the committed LLM-augmented baseline (top-1 0.95,
# post-#7c). The old gemini-2.0-flash 404s under the current Vertex enablement.
AGORA_ROUTING_LLM_MODEL=gemini-2.5-flash
# 30s matches the documented eval harness recommendation; 5s was too tight for
# Gemini 2.5 cold-start (see CLAUDE.md known-gaps).
AGORA_ROUTING_LLM_TIMEOUT_SECS=30.0
AGORA_ROUTING_LLM_LOCATION=us-central1

# --- Staff console auth ---
# When AGORA_CONSOLE_PASSWORD is empty (default), auth is disabled — no
# credentials required in local dev. Set both to enable HTTP Basic auth
# on all HTML console routes (JSON API remains unauthenticated).
AGORA_CONSOLE_USERNAME=staff
AGORA_CONSOLE_PASSWORD=
# Tenant-scoping stopgap. When set, the Basic-auth principal binds to this
# library symbol and every saga endpoint refuses operations on sagas whose
# requesting_library doesn't match. Single-tenant by construction. Empty
# default = no scoping (dev only). See docs/adr/0018-tenant-scoping-stopgap.md.
AGORA_CONSOLE_LIBRARY_SYMBOL=

# Patron portal HMAC signing key. When set, /portal endpoints require a
# `token` query param signed with this key. Empty default disables HMAC
# gating (preserves the form-entry dev experience). Production sets a
# 32-byte random value (e.g. `python -c 'import secrets; print(secrets.token_hex(32))'`)
# and rotates periodically.
AGORA_PORTAL_SIGNING_KEY=

# --- Google ADK / Vertex AI runtime (read by google-adk, not Agora) ---
GOOGLE_GENAI_USE_VERTEXAI=true
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1

# --- Anthropic API (alternative to Vertex; not used by RoutingAgent today) ---
ANTHROPIC_API_KEY=
