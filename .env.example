# Copy to .env and fill in.

# --- Agora app ---
AGORA_ENV=dev
AGORA_LOG_LEVEL=INFO
AGORA_API_HOST=0.0.0.0
AGORA_API_PORT=8000

# --- Database (Agora's own Postgres) ---
AGORA_DB_URL=postgresql+asyncpg://agora:agora@localhost:5433/agora
AGORA_DB_POOL_SIZE=10

# --- ReShare (FOLIO mod-rs) ---
# Point to your ReShare Okapi URL. For prototype dev, the in-process mock
# is used by default unless RESHARE_BASE_URL is set.
RESHARE_BASE_URL=
RESHARE_TENANT=consortium-a
RESHARE_USER=
RESHARE_PASSWORD=

# --- NCIP (mod-ncip) ---
NCIP_BASE_URL=
NCIP_AGENCY_ID=AGORA-DEV

# --- Discovery ---
SRU_LOC_URL=https://lx2.loc.gov/voyager
SRU_TIMEOUT_SECS=5

# --- Agents (Google ADK / Anthropic) ---
# If using ADK with Vertex AI:
GOOGLE_GENAI_USE_VERTEXAI=true
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1
# If using direct Anthropic API instead:
ANTHROPIC_API_KEY=

# --- Saga coordinator ---
SAGA_STALL_TIMEOUT_SECS=600
OUTBOX_RETRY_MAX_ATTEMPTS=10
